<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#faf9f5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="#141413"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="蓝牙键盘"
            android:textSize="28sp"
            android:textColor="#faf9f5"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未连接"
            android:textSize="16sp"
            android:textColor="#d97757"
            android:drawablePadding="8dp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center">

        <Button
            android:id="@+id/scan_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="扫描设备"
            android:textSize="16sp"
            android:textColor="#faf9f5"
            android:background="#d97757"
            android:padding="16dp" />

        <Button
            android:id="@+id/connect_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="连接"
            android:textSize="16sp"
            android:textColor="#141413"
            android:background="#e8e6dc"
            android:padding="16dp"
            android:enabled="false" />

    </LinearLayout>

    <TextView
        android:id="@+id/device_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="请先扫描并选择要连接的设备"
        android:textSize="14sp"
        android:textColor="#b0aea5"
        android:gravity="center" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#e8e6dc"
        android:layout_marginHorizontal="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="输入文字"
        android:textSize="18sp"
        android:textColor="#141413"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/input_edit_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:hint="在此输入要发送的文字..."
        android:gravity="top"
        android:inputType="textMultiLine"
        android:maxLines="8"
        android:padding="16dp"
        android:layout_marginHorizontal="16dp"
        android:textSize="16sp"
        android:textColor="#141413"
        android:textColorHint="#b0aea5"
        android:background="#ffffff"
        android:elevation="2dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center">

        <Button
            android:id="@+id/clear_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="清空"
            android:textSize="16sp"
            android:textColor="#141413"
            android:background="#e8e6dc"
            android:padding="16dp" />

        <Button
            android:id="@+id/send_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="发送"
            android:textSize="16sp"
            android:textColor="#faf9f5"
            android:background="#6a9bcc"
            android:padding="16dp"
            android:enabled="false" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:text="提示：连接后，输入的文字将作为键盘输入发送到电脑"
        android:textSize="12sp"
        android:textColor="#b0aea5"
        android:gravity="center" />

</LinearLayout>
